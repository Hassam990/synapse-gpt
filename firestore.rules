
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Manages user profiles, ensuring only the authenticated user can access their own profile.
    match /users/{userId} {
      // Allow reads (get) by the owner
      allow get: if isOwner(userId);

      // Prevent listing of user profiles for security.
      allow list: if false;

      // Allow create if the user ID matches the authenticated user ID
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // Allow update if the user is the owner and prevent changes to the id field
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;

      // Allow delete by the owner
      allow delete: if isOwner(userId);
    }

    // Chats subcollection for a user
    match /users/{userId}/chats/{chatId} {
      // Allow owner to do anything with their chat documents.
      allow read, write: if isOwner(userId);

      // Messages subcollection within a chat
      match /messages/{messageId} {
        // Allow owner to read and create messages.
        allow list, get, create: if isOwner(userId);
        
        // Allow owner to update any field on their own messages (e.g., to add an audio URL).
        allow update: if isOwner(userId);

        // Disallow deleting messages to preserve chat history.
        allow delete: if false;
      }
    }
  }
}
